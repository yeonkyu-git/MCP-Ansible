# Server
ANSIBLE_MCP_HOST=0.0.0.0
ANSIBLE_MCP_PORT=5000
ANSIBLE_MCP_HTTP_PATH=/mcp

# Optional: custom .env path
# ANSIBLE_MCP_ENV_FILE=/etc/ansible-mcp/.env

# Runner artifacts
ANSIBLE_MCP_RUNS_DIR=/var/lib/ansible-mcp/runs
# Optional: if omitted, this follows ANSIBLE_MCP_LOG_BACKUP_COUNT
# ANSIBLE_MCP_RUNS_BACKUP_COUNT=5

# Logging
ANSIBLE_MCP_LOG_LEVEL=INFO
ANSIBLE_MCP_LOG_DIR=/var/log/ansible-mcp
# ANSIBLE_MCP_LOG_FILE=/var/log/ansible-mcp/app.log
# ANSIBLE_MCP_AUDIT_LOG_FILE=/var/log/ansible-mcp/audit.log
ANSIBLE_MCP_LOG_MAX_BYTES=10485760
ANSIBLE_MCP_LOG_BACKUP_COUNT=5

# Path variables usable inside registry YAML paths
ANSIBLE_MCP_PLAYBOOK_ROOT=/engn/ansible/playbook
ANSIBLE_MCP_INVENTORY_ROOT=/engn/ansible
